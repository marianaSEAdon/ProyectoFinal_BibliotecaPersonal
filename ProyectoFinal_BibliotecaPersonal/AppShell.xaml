<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ProyectoFinal_BibliotecaPersonal.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:ProyectoFinal_BibliotecaPersonal"
    Title="ProyectoFinal_BibliotecaPersonal">


    <FlyoutItem Title="Mi Biblioteca" Icon="library.png">
        <ShellContent Route="library" ContentTemplate="{DataTemplate local:LibraryPage}"/>
    </FlyoutItem>
    <FlyoutItem Title="Buscar Libros" Icon="search.png">
        <ShellContent Route="search" ContentTemplate="{DataTemplate local:SearchPage}"/>
    </FlyoutItem>

    <FlyoutItem Title="Estadísticas" Icon="stats.png">
        <ShellContent Route="statistics" ContentTemplate="{DataTemplate local:StatisticsPage}"/>
    </FlyoutItem>
    <FlyoutItem Title="Agregar libro manual" Icon="add.png">
        <ShellContent Route="add" ContentTemplate="{DataTemplate local:AddBookPage}"/>
    </FlyoutItem>
    <FlyoutItem Title="Detalles y edición de libro" Icon="edit.png">
        <ShellContent Route="edit" ContentTemplate="{DataTemplate local:BookDetailPage}"/>
    </FlyoutItem>


</Shell>
