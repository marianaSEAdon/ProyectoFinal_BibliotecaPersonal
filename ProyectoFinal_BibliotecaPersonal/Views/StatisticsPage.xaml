<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProyectoFinal_BibliotecaPersonal.Views.StatisticsPage"
             Title="StatisticsPage">
    <VerticalStackLayout Padding="10">

        <!-- Canvas -->
        <GraphicsView x:Name="graphicsView"
              HeightRequest="500"
              Drawable="{Binding Drawable}" />

       
        <Label Text="{Binding TotalBooks, StringFormat='Total libros: {0}'}" />
        <Label Text="{Binding ReadBooks, StringFormat='Leídos: {0}'}" />
        <Label Text="{Binding UnreadBooks, StringFormat='Pendientes: {0}'}" />
        <Label Text="{Binding TotalPagesRead, StringFormat='Páginas leídas: {0}'}" />

    </VerticalStackLayout>
</ContentPage>