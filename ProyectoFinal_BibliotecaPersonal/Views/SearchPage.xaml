<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProyectoFinal_BibliotecaPersonal.Views.SearchPage"
             x:Name="ThisPage"
             Title="SearchPage">
    <VerticalStackLayout Padding="10" Spacing="10">

        <!-- Buscador -->
        <Entry Placeholder="Buscar libros..."
               Text="{Binding Query}" />

        <Button Text="Buscar"
                Command="{Binding SearchCommand}" />

        <!-- Resultados -->
        <CollectionView ItemsSource="{Binding Results}">
            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Frame Padding="10">
                        <Grid ColumnDefinitions="80,*,Auto">

                            <Image Grid.Column="0"
                                   Source="{Binding ThumbnailUrl}"
                                   HeightRequest="100"/>

                            <StackLayout Grid.Column="1">
                                <Label Text="{Binding Title}" FontAttributes="Bold"/>
                                <Label Text="{Binding Author}" FontSize="12"/>
                            </StackLayout>

                            <Button Grid.Column="2"
                                    Text="+"
                                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.AddBookFromApiCommand}"
                                    CommandParameter="{Binding .}" />
                        </Grid>
                    </Frame>

                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>